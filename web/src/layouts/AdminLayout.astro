---
import { AdminSidebar } from "../components/layout/AdminSidebar";
import { ToastContainer } from "../components/custom/Toast";
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Panel de Administración - FoodApp" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Admin FoodApp</title>
    <script is:inline>
      (function () {
        try {
          const storedTheme = localStorage.getItem("theme");
          const systemTheme = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;
          if (
            storedTheme === "dark" ||
            (!storedTheme && systemTheme) ||
            (storedTheme === "system" && systemTheme)
          ) {
            document.documentElement.classList.add("dark");
          } else {
            document.documentElement.classList.remove("dark");
          }
        } catch (e) {
          console.error(e);
        }
      })();

      document.addEventListener("astro:after-swap", () => {
        try {
          const storedTheme = localStorage.getItem("theme");
          const systemTheme = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;
          if (
            storedTheme === "dark" ||
            (!storedTheme && systemTheme) ||
            (storedTheme === "system" && systemTheme)
          ) {
            document.documentElement.classList.add("dark");
          } else {
            document.documentElement.classList.remove("dark");
          }
        } catch (e) {
          console.error(e);
        }
      });
    </script>
  </head>
  <body
    class="bg-background text-foreground antialiased flex h-screen overflow-hidden"
  >
    <AdminSidebar client:load client:only="react" currentPath={currentPath} />

    <main class="flex-1 overflow-y-auto bg-secondary/20 p-4 md:p-8">
      <slot />
    </main>

    <ToastContainer client:load client:only="react" />
  </body>
</html>
