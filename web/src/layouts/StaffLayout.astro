---
import { StaffSidebar } from "../components/layout/StaffSidebar";
import { ToastContainer } from "../components/custom/Toast";
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Staff FoodApp</title>

    <script is:inline>
      (function () {
        function applyTheme() {
          try {
            const storedTheme = localStorage.getItem("theme");
            const systemTheme = window.matchMedia(
              "(prefers-color-scheme: dark)",
            ).matches;
            if (
              storedTheme === "dark" ||
              (!storedTheme && systemTheme) ||
              (storedTheme === "system" && systemTheme)
            ) {
              document.documentElement.classList.add("dark");
            } else {
              document.documentElement.classList.remove("dark");
            }
          } catch (e) {
            console.error(e);
          }
        }
        applyTheme();
        document.addEventListener("astro:after-swap", applyTheme);
        document.addEventListener("astro:page-load", applyTheme);
      })();
    </script>
  </head>

  <body class="min-h-screen bg-background flex text-foreground antialiased">
    <StaffSidebar client:load client:only="react" currentPath={currentPath} />

    <main class="flex-1 lg:ml-0">
      <div class="p-4 lg:p-8 pt-16 lg:pt-8">
        <slot />
      </div>
    </main>

    <ToastContainer client:load client:only="react" />
  </body>
</html>
