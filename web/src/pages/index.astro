---
import Layout from "../layouts/Layout.astro";
import { FiSearch, FiMapPin, FiClock } from "react-icons/fi";

// Datos estáticos para la landing (Demo)
const featuredRestaurants = [
  {
    id: "1",
    name: "La Trattoria",
    image: "https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=600",
    category: "Italiana",
  },
  {
    id: "2",
    name: "Burger King Center",
    image: "https://images.unsplash.com/photo-1586816001966-79b736744398?w=600",
    category: "Americana",
  },
  {
    id: "3",
    name: "Sushi Master",
    image: "https://images.unsplash.com/photo-1579871494447-9811cf80d66c?w=600",
    category: "Japonesa",
  },
];
---

<Layout title="Inicio">
  <section class="relative bg-primary/5 py-20 lg:py-32">
    <div
      class="mx-auto max-w-7xl px-4 flex flex-col md:flex-row items-center gap-12"
    >
      <div class="flex-1 space-y-6 text-center md:text-left">
        <h1
          class="text-4xl md:text-6xl font-bold tracking-tight text-foreground"
        >
          Tu comida favorita, <br />
          <span class="text-primary">en la puerta de tu casa</span>
        </h1>
        <p class="text-lg text-muted-foreground md:max-w-xl">
          Descubre los mejores restaurantes locales, explora menús variados y
          recibe tu pedido en minutos.
        </p>
        <div
          class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start"
        >
          <a
            href="/restaurants"
            class="inline-flex h-12 items-center justify-center rounded-lg bg-primary px-8 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90"
          >
            Explorar Restaurantes
          </a>
          <a
            href="/register"
            class="inline-flex h-12 items-center justify-center rounded-lg border border-input bg-background px-8 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
          >
            Crear cuenta
          </a>
        </div>
      </div>
      <div class="flex-1 w-full max-w-md md:max-w-full">
        <div
          class="relative aspect-square rounded-2xl overflow-hidden shadow-2xl rotate-3 hover:rotate-0 transition-transform duration-500"
        >
          <img
            src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=800"
            alt="Comida deliciosa"
            class="object-cover w-full h-full"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-background">
    <div class="mx-auto max-w-7xl px-4">
      <div class="grid md:grid-cols-3 gap-8">
        <div
          class="flex flex-col items-center text-center p-6 rounded-xl border border-border bg-card"
        >
          <div class="p-4 bg-primary/10 rounded-full text-primary mb-4">
            <FiMapPin size={32} />
          </div>
          <h3 class="text-xl font-bold mb-2">Cerca de ti</h3>
          <p class="text-muted-foreground">
            Encuentra restaurantes en tu zona con los mejores tiempos de
            entrega.
          </p>
        </div>
        <div
          class="flex flex-col items-center text-center p-6 rounded-xl border border-border bg-card"
        >
          <div class="p-4 bg-primary/10 rounded-full text-primary mb-4">
            <FiClock size={32} />
          </div>
          <h3 class="text-xl font-bold mb-2">Entrega Rápida</h3>
          <p class="text-muted-foreground">
            Nuestros repartidores llevan tu comida caliente y a tiempo.
          </p>
        </div>
        <div
          class="flex flex-col items-center text-center p-6 rounded-xl border border-border bg-card"
        >
          <div class="p-4 bg-primary/10 rounded-full text-primary mb-4">
            <FiSearch size={32} />
          </div>
          <h3 class="text-xl font-bold mb-2">Variedad</h3>
          <p class="text-muted-foreground">
            Desde sushi hasta tacos, tenemos opciones para todos los gustos.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-secondary/20">
    <div class="mx-auto max-w-7xl px-4">
      <div class="flex justify-between items-center mb-8">
        <h2 class="text-3xl font-bold">Populares esta semana</h2>
        <a href="/restaurants" class="text-primary font-medium hover:underline"
          >Ver todos &rarr;</a
        >
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          featuredRestaurants.map((rest) => (
            <a
              href={`/restaurants/${rest.id}`}
              class="group block overflow-hidden rounded-xl bg-card shadow-sm hover:shadow-lg transition-all"
            >
              <div class="relative aspect-video overflow-hidden">
                <img
                  src={rest.image}
                  alt={rest.name}
                  class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-300"
                />
              </div>
              <div class="p-4">
                <h3 class="text-lg font-bold text-foreground">{rest.name}</h3>
                <p class="text-sm text-muted-foreground">{rest.category}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
